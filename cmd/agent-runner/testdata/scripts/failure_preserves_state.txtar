# Test that a failed workflow preserves a state file for resumption.
! exec agent-runner workflow
stdout 'to resume: agent-runner --resume '
exec find .agent-runner -name state.json
stdout state\.json

-- .agent-runner/workflows/workflow.yaml --
name: e2e-failure
steps:
  - id: first
    command: echo ok
  - id: second
    command: "false"
