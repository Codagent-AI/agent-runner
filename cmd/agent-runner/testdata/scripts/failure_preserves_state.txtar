# Test that a failed workflow preserves a state file for resumption.
! exec agent-runner workflow.yaml
stdout 'to resume: agent-runner --resume --session'
exec find .agent-runner -name state.json
stdout state\.json

-- workflow.yaml --
name: e2e-failure
steps:
  - id: first
    mode: shell
    command: echo ok
  - id: second
    mode: shell
    command: "false"
