# Test that the openspec engine is registered and sub-workflows with engine
# configs can be loaded. This catches missing blank imports for engine packages.
exec agent-runner workflow test-change
stdout 'engine loaded'

-- .agent-runner/workflows/workflow.yaml --
name: engine-test
params:
  - name: change_name
    required: true
steps:
  - id: plan
    workflow: child.yaml
    params:
      change_name: "{{change_name}}"

-- .agent-runner/workflows/child.yaml --
name: child-with-engine
params:
  - name: change_name
    required: true
engine:
  type: openspec
  change_param: change_name
steps:
  - id: step1
    command: echo engine loaded
